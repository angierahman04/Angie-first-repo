import time
import threading
import requests
import RPi.GPIO as GPIO

# ---------- CONFIG ----------
NIGHTSCOUT_URL = "https://glowabetes.onrender.com/api/v1/entries.json?count=1"
POLL_SECONDS = 15
DEMO_SECONDS = 120

# GPIO pins (BCM numbering)
PIN_R = 17
PIN_G = 27
PIN_B = 22

# ---------- GPIO SETUP ----------
GPIO.setmode(GPIO.BCM)
GPIO.setup(PIN_R, GPIO.OUT)
GPIO.setup(PIN_G, GPIO.OUT)
GPIO.setup(PIN_B, GPIO.OUT)

# Common-anode RGB LED:
# LOW = ON, HIGH = OFF
def set_rgb(r: int, g: int, b: int) -> None:
    GPIO.output(PIN_R, GPIO.LOW if r else GPIO.HIGH)
    GPIO.output(PIN_G, GPIO.LOW if g else GPIO.HIGH)
    GPIO.output(PIN_B, GPIO.LOW if b else GPIO.HIGH)

def color_for_glucose(glucose: int) -> str:
    if glucose < 80:
        set_rgb(1, 0, 0)      # RED
        return "RED (LOW)"
    elif 80 <= glucose <= 120:
        set_rgb(0, 1, 0)      # GREEN
        return "GREEN (IDEAL)"
    elif 120 < glucose <= 180:
        set_rgb(1, 1, 0)      # YELLOW
        return "YELLOW (ELEVATED)"
    else:
        set_rgb(1, 0, 0)      # RED
        return "RED (HIGH)"

def fetch_latest_glucose() -> int:
    r = requests.get(NIGHTSCOUT_URL, timeout=10)
    r.raise_for_status()
    data = r.json()
    if not data:
        raise ValueError("Nightscout returned no entries yet.")
    return int(data[0]["sgv"])

# ---------- DEMO OVERRIDE ----------
lock = threading.Lock()
demo_active_until = 0.0
demo_value = None

def set_demo(value: int) -> None:
    global demo_active_until, demo_value
    with lock:
        demo_value = value
        demo_active_until = time.time() + DEMO_SECONDS

def get_active_value(real_value: int):
    with lock:
        if time.time() < demo_active_until and demo_value is not None:
            return demo_value, True
    return real_value, False

def input_thread():
    print("\nDemo override: type a glucose value (e.g. 95, 150, 240).")
    print("Type 'q' to quit.\n")
    while True:
        s = input("> ").strip().lower()
        if s == "q":
            break
        if not s:
            continue
        try:
            v = int(s)
            set_demo(v)
            print(f"[demo] Using {v} mg/dL for {DEMO_SECONDS} seconds.")
        except ValueError:
            print("Please enter an integer or 'q'.")

def main():
    t = threading.Thread(target=input_thread, daemon=True)
    t.start()

    last_color = None

    try:
        while True:
            try:
                real = fetch_latest_glucose()
            except Exception as e:
                print(f"[error] Nightscout fetch failed: {e}")
                set_rgb(0, 0, 1)  # BLUE error blink
                time.sleep(0.2)
                set_rgb(0, 0, 0)
                time.sleep(0.8)
                continue

            value, is_demo = get_active_value(real)
            color = color_for_glucose(value)

            tag = "demo" if is_demo else "real"
            if color != last_color:
                print(f"[{tag}] glucose={value} -> {color}")
                last_color = color

            time.sleep(POLL_SECONDS)

    except KeyboardInterrupt:
        pass
    finally:
        set_rgb(0, 0, 0)
        GPIO.cleanup()

if __name__ == "__main__":
    main()



